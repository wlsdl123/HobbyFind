<!DOCTYPE>
<html>
    <head>
        <title>CSS 1</title>
        <style>
            body {
                font-family:arial, sans-serif ;
                margin: 0;
                padding: 0;
                background-color: rgb(218, 215, 250);

            }

            .chat{
               border: 2px dashed red; 
               width: 100%;
                max-width: 300px;
                margin: auto;
                padding: 20px;
                background-color: (0, 0, 1);
            }
            .message {
                display: flex;
                flex-direction: column;
                margin-bottom: 10px;
             }

             .message-info {
                font-size: 0.85em;
                color: #666;
             }
             
             .message-body {
                max-width: 80%;
                padding: 10px;
                border-radius: 10px;
                margin: 5px 0;
             }

             .message-body:hover {
                transition: box-shadow 0.8s;
                box-shadow: 0 0 15px red;
             }

             .friend .message-time {
                font-size: 0.75em;
                color: #999;
                align-self: flex-start;
             }
             .me .message-time {
                font-size: 0.75em;
                color: #999;
                align-self: flex-end;
             }
             .friend .message-body {
                background-color: #fff;
                align-self: flex-start;
             }


             .me .message-body {
                background-color: rgb(47, 0, 255);
                color: #ffffff;
                align-self: flex-end;
                border-radius: 10px 10px 0 10px;
             }


        </style>


    </head>
    <body>
        <div class="chat">
            <div class="message friend">
            <div class="message-info">데이원컴퍼니</div>
            <p class="message-body">안녕하세요.</p>
            <time class="message-time">오후5:17</time>
        </div>
        <div class="message me">
         <p class="message body">네~</p>
         <time class="message-time">오후7:17</time>





        </div>


    </body>


</html>